# ============================================
# Cripto Trading Bot - Variables de entorno
# Copia este archivo a .env y rellena los valores.
# NUNCA subas el .env real a git (está en .gitignore).
# ============================================

# --- Modo de ejecución (requerido decidir, tiene default) ---
# EXECUTION_MODE=paper | testnet   (default: paper)
#
#   paper   -> Réplica exacta del entorno del backtest de 24h en vivo: usa datos
#              públicos de MAINNET (OHLCV + WebSocket) pero los fills son
#              SIMULADOS al precio actual, con contabilidad local y fee del
#              0.08% round-trip. NO requiere API keys de Binance.
#   testnet -> Ejecución real de órdenes demo en Binance TESTNET (venue
#              consistente: WebSocket de testnet). Requiere las claves de abajo.
#
# EXECUTION_MODE=paper

# --- Binance Futures TESTNET (solo necesarias si EXECUTION_MODE=testnet) ---
# En modo paper NO son necesarias: el bot no envía ninguna orden al exchange.
# API key de https://testnet.binancefuture.com
BINANCE_TESTNET_KEY=
# API secret de https://testnet.binancefuture.com
BINANCE_TESTNET_SECRET=

# --- Telegram (requeridas) ---
# Token del bot de Telegram (lo entrega @BotFather)
TELEGRAM_BOT_API=
# Chat ID personal autorizado (control de acceso; obténlo con @userinfobot)
TELEGRAM_ID=

# --- Trading (opcional) ---
# Apalancamiento de futuros usado por el bot. Default: 3
# BOT_LEVERAGE=3
