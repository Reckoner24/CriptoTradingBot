# ============================================
# Cripto Trading Bot - Variables de entorno
# Copia este archivo a .env y rellena los valores.
# NUNCA subas el .env real a git (está en .gitignore).
# ============================================

# --- Modo de ejecución (requerido decidir, tiene default) ---
# EXECUTION_MODE=paper | testnet   (default: paper)
#
#   paper   -> Réplica exacta del entorno del backtest de 24h en vivo: usa datos
#              públicos de MAINNET (OHLCV + WebSocket) pero los fills son
#              SIMULADOS al precio actual, con contabilidad local y fee del
#              0.08% round-trip. NO requiere API keys de Binance.
#   testnet -> Ejecución real de órdenes demo en Binance TESTNET (venue
#              consistente: WebSocket de testnet). Requiere las claves de abajo.
#
# EXECUTION_MODE=paper

# --- Binance Futures TESTNET (solo necesarias si EXECUTION_MODE=testnet) ---
# En modo paper NO son necesarias: el bot no envía ninguna orden al exchange.
# API key de https://testnet.binancefuture.com
BINANCE_TESTNET_KEY=
# API secret de https://testnet.binancefuture.com
BINANCE_TESTNET_SECRET=

# --- Telegram (requeridas) ---
# Token del bot de Telegram (lo entrega @BotFather)
TELEGRAM_BOT_API=
# Chat ID personal autorizado (control de acceso; obténlo con @userinfobot)
TELEGRAM_ID=

# --- Trading (opcional) ---
# Apalancamiento de futuros usado por el bot. Default de codigo: 10
# BOT_LEVERAGE=10

# --- Controles de riesgo diario ---
# El freno gradual se activa en PAPER por defecto; el kill switch permanece
# apagado hasta habilitarlo deliberadamente al operar dinero real.
RISK_CONTROLS_ENABLED=true
KILL_SWITCH_ENABLED=false
# Reducir tamaño si la pérdida desde el balance inicial del día UTC alcanza 3%.
DAILY_DRAWDOWN_REDUCE_PCT=0.03
# Solo bloquea nuevas entradas si KILL_SWITCH_ENABLED=true.
DAILY_DRAWDOWN_HALT_PCT=0.06
LOSS_STREAK_REDUCE_AT=3
RISK_REDUCED_MULTIPLIER=0.50

# --- Calidad de estrategia ---
# Grid sólo cuando ADX indica un mercado sin tendencia fuerte.
MAX_ADX_FOR_GRID=25
# Coste adverso por lado modelado sólo en los replays/WFO (0.02%).
REPLAY_SLIPPAGE_PCT=0.0002
# Momentum guard no vende una microganancia; exige 50% del camino al TP.
MOMENTUM_GUARD_MIN_TP_FRAC=0.50

# --- Filtro RSI ---
# Activar/desactivar filtro RSI en entradas (default: true).
# RSI_FILTER=true
# LONG solo cuando RSI <= RSI_LONG_MAX (dip). Default de codigo: 45.
# RSI_LONG_MAX=45
# SHORT solo cuando RSI >= RSI_SHORT_MIN (rally). Default de codigo: 55.
# RSI_SHORT_MIN=55

# --- Filtro de volumen relativo ---
# Activar/desactivar filtro de volumen (default: false). No abrir si volumen
# relativo < VOL_MIN (sin interes) o > VOL_MAX (panico/euforia).
# VOL_FILTER=false
# VOL_MIN=0.5
# VOL_MAX=3.0

# --- Gobernador de riesgo (tercer nivel) ---
# Pausa completa de entradas si perdida neta de la ventana >= 8% del balance.
# RISK_GOVERNOR_HALT2_PNL_PCT=-0.08

# --- Asignacion de capital por simbolo ---
# Pesos relativos: SOL recibe mas capital (mejor PF historico), BTC menos.
# El WFO siempre optimiza a $250 fijo; el peso solo escala el capital operativo.
# ALLOCATION_WEIGHT_BTC=0.3
# ALLOCATION_WEIGHT_ETH=1.0
# ALLOCATION_WEIGHT_SOL=1.7

# --- Rango de risk_pct por simbolo en el WFO ---
# SOL puede arriesgar mas (PF OOS alto); BTC se limita para contener sangrado.
# RISK_PCT_MIN_SOL=0.07
# RISK_PCT_MAX_SOL=0.15
# RISK_PCT_MIN_BTC=0.03
# RISK_PCT_MAX_BTC=0.08
